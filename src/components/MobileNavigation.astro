---
// src/components/MobileNavigation.astro
// 移动端专用导航组件 - 完全独立于桌面端

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

// 导航链接
const navLinks = [
  { href: "/m/", label: "影集", icon: "grid_view" },
  { href: "/m/daily", label: "日常", icon: "photo_library" },
];

// 更新链接的 active 状态
const activeLinks = navLinks.map((link) => ({
  ...link,
  isActive:
    currentPath === link.href.replace(/^\/m/, "/") ||
    (currentPath.startsWith(link.href.replace(/^\/m/, "/")) &&
      link.href !== "/m/"),
}));
---

<nav class="mobile-nav">
  <!-- 顶部标题栏 -->
  <header class="nav-header">
    <a href="/" class="nav-title">
      <span class="logo-text">拙石</span>
      <span class="logo-sub">ZHUOSHI</span>
    </a>
    
    <!-- 桌面端入口按钮 -->
    <a href="/" class="desktop-entry-btn">
      <span class="material-symbols-outlined">desktop_windows</span>
      <span>桌面版</span>
    </a>
  </header>

  <!-- 底部标签栏 -->
  <footer class="nav-tabs">
    {activeLinks.map(link => (
      <a 
        href={link.href}
        class:list={[
          "tab-item",
          link.isActive && "active"
        ]}
        data-href={link.href}
      >
        <span class="material-symbols-outlined tab-icon">
          {link.icon}
        </span>
        <span class="tab-label">{link.label}</span>
      </a>
    ))}
  </footer>
</nav>

<style>
  /* 固定在底部的导航 */
  .mobile-nav {
    position: fixed;
    left: 0;
    right: 0;
    top: 0;
    bottom: 0;
    pointer-events: none;
    z-index: 50;
    display: flex;
    flex-direction: column;
  }

  /* 顶部标题栏 */
  .nav-header {
    position: sticky;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    padding-top: calc(env(safe-area-inset-top, 0px) + 16px);
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.8), transparent);
    pointer-events: auto;
  }

  .nav-title {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .logo-text {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.15em;
  }

  .logo-sub {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.5);
  }

  /* 桌面端入口 */
  .desktop-entry-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.2s ease;
  }

  .desktop-entry-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  .desktop-entry-btn .material-symbols-outlined {
    font-size: 16px;
  }

  /* 底部标签栏 */
  .nav-tabs {
    position: sticky;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-around;
    padding: 12px 20px;
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
    pointer-events: auto;
  }

  .tab-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 8px 20px;
    border-radius: 16px;
    transition: all 0.2s ease;
    min-width: 80px;
  }

  .tab-item.active {
    background: rgba(255, 255, 255, 0.15);
  }

  .tab-item.active .tab-icon,
  .tab-item.active .tab-label {
    color: #fff;
  }

  .tab-icon {
    font-size: 22px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s ease;
  }

  .tab-label {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    transition: color 0.2s ease;
  }

  /* 按下效果 */
  .tab-item:active {
    transform: scale(0.95);
  }
</style>

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" rel="stylesheet" />
