---
import fs from "node:fs/promises";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";

const allImages = import.meta.glob("../images/*/*.{jpg,jpeg,png,webp}", {
  eager: true,
});

type CollectionGroup = {
  count: number;
  cover: string;
  images: string[];
  external: string;
  internal: string;
};
const collectionGroups: Record<string, CollectionGroup> = {};

// 扫描 images 目录下的所有子文件夹
const imageDir = path.join(process.cwd(), "src/images");
let folders: string[] = [];
try {
  const entries = await fs.readdir(imageDir, { withFileTypes: true });
  folders = entries
    .filter((entry) => entry.isDirectory())
    .map((entry) => entry.name);
} catch (e) {}

// 读取每个文件夹的 intro.md
type FolderMeta = { external: string; internal: string };
const folderMeta: Record<string, FolderMeta> = {};
for (const folder of folders) {
  const introPath = path.join(imageDir, folder, "intro.md");
  try {
    const content = await fs.readFile(introPath, "utf-8");

    // 用 --- 分隔外部和内部内容
    const parts = content.split(/^---$/m);

    let external = "";
    let internal = "";

    if (parts.length >= 2) {
      // 有分隔符：前部分是外部，后部分是内部
      external = parts[0].trim();
      internal = parts.slice(1).join(" ").trim();
    } else {
      // 没有分隔符：全部作为内部内容
      internal = content.trim();
    }

    // 过滤掉 markdown 标题，取有意义的内容
    const filterContent = (text: string) => {
      const lines = text.split("\n").filter((l) => l.trim());
      const meaningfulLines = lines.filter(
        (l) => !l.match(/^#{1,6}\s/) && l.trim().length > 0,
      );
      return meaningfulLines.slice(0, 3).join(" ").slice(0, 200);
    };

    folderMeta[folder] = {
      external: filterContent(external),
      internal: filterContent(internal),
    };
  } catch (e) {
    // 没有 intro.md，使用默认
  }
}

Object.entries(allImages).forEach(([filePath, mod]) => {
  const imgData = (mod as any).default;
  const parts = filePath.split("/");
  const folderName = parts[parts.length - 2];

  if (folderName === "images") return;

  if (!collectionGroups[folderName]) {
    const meta = folderMeta[folderName] || { external: "", internal: "" };
    collectionGroups[folderName] = {
      count: 0,
      cover: imgData.src,
      images: [],
      external: meta.external,
      internal: meta.internal,
    };
  }
  collectionGroups[folderName].count++;
  collectionGroups[folderName].images.push(imgData.src);
});

const sortedCollections = Object.keys(collectionGroups).sort();
const currentPath: string = "";
---

<BaseLayout title="首页" description="摄影作品集">
  <div class="w-full bg-white dark:bg-black text-black dark:text-white font-mono min-h-screen">

    <header class="fixed top-0 left-0 w-full z-50 border-b-2 border-black dark:border-white bg-white dark:bg-black flex justify-center">
      <div class="w-full flex items-center justify-between px-4 py-3 max-w-7xl">
        <a href="/" class="text-xl font-bold tracking-widest hover:underline">拙石</a>
        <span class="text-sm">首页</span>
      </div>
    </header>

    <main class="w-full pt-16 min-h-screen flex justify-center">
      <div class="w-full px-4 py-8 md:py-12 max-w-7xl">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

          <div class="border-2 border-black dark:border-white">
            {sortedCollections.length > 0 ? (
              <ul>
                {sortedCollections.map((name, index) => {
                  const info = collectionGroups[name];
                  const rawName = name.replace(/^\d+_/, '');
                  const parts = rawName.split('_');
                  const zhTitle = parts[0] || rawName;
                  const enTitle = parts[1] || "";

                return (
                  <li>
                    <a
                      href={`/collection/${name}`}
                      class="collection-item block py-4 px-4 border-b-2 border-black dark:border-white last:border-b-0 no-underline flex items-baseline justify-between hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black"
                      data-cover={info.cover}
                      data-external={info.external || ''}
                    >
                        <span class="text-lg md:text-xl font-bold">
                          {(index + 1).toString().padStart(2, '0')}. {zhTitle}
                        </span>
                        <span class="text-xs md:text-sm uppercase tracking-widest">
                          {enTitle} [{info.count}]
                        </span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            ) : (
              <div class="p-8 text-center border-b-2 border-black dark:border-white">
                <p class="text-lg">暂无影集</p>
              </div>
            )}
          </div>

          <div class="hidden md:block">
            <div class="sticky top-20 border-2 border-black dark:border-white p-2">
              <div class="aspect-[4/3] bg-black overflow-hidden relative protected-gallery">
                <div class="protection-overlay" aria-hidden="true"></div>
                <img
                  id="preview-img"
                  src={sortedCollections.length > 0 ? collectionGroups[sortedCollections[0]].cover : ''}
                  alt="预览"
                  class="w-full h-full object-cover absolute inset-0"
                />
                <div
                  id="static-overlay"
                  class="absolute inset-0 opacity-0 pointer-events-none"
                  style="background: repeating-radial-gradient(#000 0 0.0001%, #fff 0 0.0002%) 50% 0/2000px 2000px, repeating-conic-gradient(#000 0 0.0001%, #fff 0 0.0002%) 60% 60%/2000px 2000px; background-blend-mode: difference;"
                ></div>
              </div>
              <div class="mt-3 text-center">
                <p id="preview-title" class="text-sm font-bold">
                  {sortedCollections.length > 0 ? sortedCollections[0].replace(/^\d+_/, '').split('_')[0] : ''}
                </p>
                <p id="preview-desc" class="text-xs mt-1 opacity-70">
                  {sortedCollections.length > 0 ? collectionGroups[sortedCollections[0]].external : ''}
                </p>
              </div>
            </div>
          </div>

        </div>

        <div class="mt-12 pt-6 border-t-4 border-black dark:border-white">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">

            <div class="flex flex-col gap-2 text-sm">
              <a href="/stories" class="font-bold hover:underline">[ 故事 ]</a>
              <a href="/daily" class="font-bold hover:underline">[ 日常 ]</a>
              <a href="#" class="font-bold hover:underline">[ 简历 ]</a>
              <a href="#" class="font-bold hover:underline">[ 邮箱 ]</a>
              <a href="#" class="font-bold hover:underline">[ Instagram ]</a>
            </div>

            <div class="text-sm">
              <p>{sortedCollections.length} 个影集 · {Object.values(collectionGroups).reduce((acc, g) => acc + g.count, 0)} 张照片</p>
            </div>
          </div>
        </div>

      </div>
    </main>

  </div>
</BaseLayout>

<script>
  function initHomepage() {
    const previewImg = document.getElementById('preview-img') as HTMLImageElement;
    const previewTitle = document.getElementById('preview-title');
    const previewDesc = document.getElementById('preview-desc');
    const staticOverlay = document.getElementById('static-overlay');
    const collectionItems = document.querySelectorAll('.collection-item');

    // 保存第一个项目的默认数据
    const firstItem = collectionItems[0] as HTMLElement;
    const defaultCover = firstItem?.dataset.cover || '';
    const defaultExternal = firstItem?.dataset.external || '';
    const defaultTitle = firstItem?.querySelector('span')?.textContent?.replace(/^\d+\.\s*/, '') || '';

    let staticTimeout: ReturnType<typeof setTimeout>;

    // 初始化时显示默认图片
    if (previewImg && defaultCover) {
      previewImg.src = defaultCover;
    }

    collectionItems.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        // 清除花屏定时器
        clearTimeout(staticTimeout);

        const cover = (item as HTMLElement).dataset.cover;
        const external = (item as HTMLElement).dataset.external || '';
        const title = item.querySelector('span')?.textContent?.replace(/^\d+\.\s*/, '') || '';

        if (previewImg && cover) {
          previewImg.src = cover;
          previewImg.style.opacity = '1';
        }
        if (previewTitle && title) {
          previewTitle.textContent = title;
        }
        if (previewDesc) {
          previewDesc.textContent = external;
        }

        // 隐藏花屏
        if (staticOverlay) {
          staticOverlay.style.opacity = '0';
        }
      });

      item.addEventListener('mouseleave', () => {
        // 延迟显示花屏效果
        staticTimeout = setTimeout(() => {
          // 显示花屏
          if (staticOverlay) {
            staticOverlay.style.opacity = '1';
          }

          // 0.75秒后变黑
          setTimeout(() => {
            // 图片变透明
            if (previewImg) {
              previewImg.style.opacity = '0';
            }

            // 标题和描述清空
            if (previewTitle) {
              previewTitle.textContent = '';
            }
            if (previewDesc) {
              previewDesc.textContent = '';
            }

            // 隐藏花屏（显示纯黑背景）
            if (staticOverlay) {
              staticOverlay.style.opacity = '0';
            }
          }, 750);
        }, 300);
      });
    });
  }

  initHomepage();
  document.addEventListener('astro:page-load', initHomepage);
</script>

<style>
  /* 粗野主义风格 - 保留花屏效果 */
  a {
    text-decoration: none;
  }

  /* 列表项 hover 效果 */
  .collection-item:hover {
    cursor: pointer;
  }

  /* 花屏动画 - 大颗粒噪声 */
  #static-overlay {
    transition: opacity 0.3s ease;
    animation: staticNoise 0.4s steps(2) infinite;
    background-size: 20px 20px, 30px 30px;
  }

  @keyframes staticNoise {
    0% {
      background-position: 0 0, 0 0;
    }
    50% {
      background-position: 10px 10px, -10px -10px;
    }
    100% {
      background-position: 0 0, 0 0;
    }
  }
</style>