---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// 获取所有故事（使用 Astro 内容集合）
const stories = await getCollection("stories");

// 按日期倒序
stories.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);
---

<BaseLayout title="故事" description="照片故事">
  <div class="w-full bg-white dark:bg-black text-black dark:text-white font-mono min-h-screen">

    <header class="fixed top-0 left-0 w-full z-50 border-b-2 border-black dark:border-white bg-white dark:bg-black flex justify-center">
      <div class="w-full flex items-center justify-between px-4 py-3 max-w-7xl">
        <a href="/" class="text-xl font-bold tracking-widest hover:underline">拙石</a>
        <span class="text-sm">故事</span>
      </div>
    </header>

    <div class="w-full flex justify-center">
      <div class="w-full pt-28 pb-8 px-4 md:px-8 max-w-7xl border-b-2 border-black dark:border-white">
        <h1 class="text-4xl md:text-6xl font-serif font-light tracking-tight">
          故事
        </h1>
        <p class="mt-2 text-sm opacity-70">
          定格时光，讲述画面背后的故事。
        </p>
      </div>
    </div>

    <main class="w-full px-4 md:px-8 pb-16 flex justify-center">
      {stories.length > 0 ? (
        <div class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-8 max-w-7xl">
          {stories.map((story) => (
            <a
              href={`/stories/${story.slug}`}
              class="story-card border-2 border-black dark:border-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors group h-[400px] flex flex-col"
            >
              <div class="aspect-4/3 overflow-hidden border-b-2 border-black dark:border-white">
                <img
                  src={story.data.cover.src}
                  alt={story.data.title}
                  class="w-full h-full object-cover"
                />
              </div>
              
              <div class="p-4">
                <div class="flex items-baseline justify-between mb-2">
                  <span class="text-xs font-bold uppercase">
                    {new Date(story.data.date).toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
                  </span>
                </div>
                <h2 class="text-lg font-bold mb-2">{story.data.title}</h2>
                <p class="text-sm opacity-70 line-clamp-2">
                  {story.data.excerpt}
                </p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="w-full flex flex-col items-center justify-center min-h-[40vh] pt-24 max-w-7xl">
          <div class="text-center border-2 border-black dark:border-white p-8">
            <h3 class="font-serif text-2xl mb-4">暂无故事</h3>
            <p class="text-sm">
              请在 <code class="bg-gray-200 dark:bg-gray-800 px-1">src/stories/</code> 文件夹中添加 Markdown 文件
            </p>
          </div>
        </div>
      )}
    </main>

    <div class="w-full flex justify-center">
      <div class="w-full px-4 pb-8 max-w-7xl">
        <div class="pt-6 border-t-4 border-black dark:border-white">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div class="flex flex-col gap-2 text-sm">
              <a href="/" class="font-bold hover:underline">[ 首页 ]</a>
              <a href="/daily" class="font-bold hover:underline">[ 日常 ]</a>
              <a href="#" class="font-bold hover:underline">[ 邮箱 ]</a>
              <a href="#" class="font-bold hover:underline">[ Instagram ]</a>
            </div>
            <div class="text-sm">
              <p>{stories.length} 个故事</p>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>

<style>
  /* 粗野主义风格 */
  a {
    text-decoration: none;
  }

  .story-card {
    cursor: pointer;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>