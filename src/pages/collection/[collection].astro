    pointer-events: none;
}

#details-overlay:not(.opacity-0) {
    opacity: 1;
    pointer-events: auto;
}

/* 详情面板内部元素入场动画 */
#details-overlay:not(.opacity-0) .w-2\/3,
#details-overlay:not(.opacity-0) .w-1\/3 {
    animation: slideIn 0.35s ease-out forwards;
}

#details-overlay:not(.opacity-0) .w-2\/3 {
    animation-delay: 0.05s;
    transform: translateX(-20px);
    opacity: 0;
}

#details-overlay:not(.opacity-0) .w-1\/3 {
    animation-delay: 0.1s;
    transform: translateX(20px);
    opacity: 0;
}

@keyframes slideIn {
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* 移动端详情面板入场 */
#details-overlay:not(.opacity-0) .absolute.bottom-0 {
