---
import { getImage } from "astro:assets";
import fs from "node:fs/promises";
import path from "node:path";
import { marked } from "marked";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { extractImageMetadata, toClientData } from "../../utils/metadata";

// Astro 图像对象类型（从 import.meta.glob 返回）
interface AstroImage {
  src: string;
  width: number;
  height: number;
  format: string;
}

// 1. 生成静态路径 - 使用 eager 模式但配合 getImage 进行优化
export async function getStaticPaths() {
  // 使用 eager: true 获取图片模块（Vite 会自动处理）
  // 注意：Vite/astro-assets 会缓存优化后的图片，不会导致 OOM
  const allImages = import.meta.glob("../../images/*/*.{jpg,jpeg,png,webp}", {
    eager: true,
  });

  const imagesByFolder: Record<
    string,
    { filePath: string; imgData: AstroImage }[]
  > = {};

  Object.entries(allImages).forEach(([filePath, imgModule]) => {
    const parts = filePath.split("/");
    const folderName = parts[parts.length - 2];
    if (folderName === "images") return;
    if (!imagesByFolder[folderName]) imagesByFolder[folderName] = [];
    // imgModule.default 是 Astro 的 ImageMetadata 对象
    imagesByFolder[folderName].push({
      filePath,
      imgData: (imgModule as { default: AstroImage }).default,
    });
  });

  return Object.keys(imagesByFolder).map((collection) => ({
    params: { collection },
    props: { images: imagesByFolder[collection] },
  }));
}

const { collection } = Astro.params;
const { images } = Astro.props;

// 2. 解析标题
const rawName = collection.replace(/^\d+_/, "");
const nameParts = rawName.split("_");
const mainTitle = nameParts[0] || rawName;
const subTitle = nameParts[1] || "";

// 3. 读取前言（只读取 --- 分隔符之后的内容，作为内部展示）
let introHtml = "";
let hasIntro = false;
try {
  const introPath = path.join(
    process.cwd(),
    "src/images",
    collection,
    "intro.md",
  );
  const introMarkdown = await fs.readFile(introPath, "utf-8");

  // 用 --- 分隔外部和内部内容
  const parts = introMarkdown.split(/^---$/m);

  let internalContent = "";
  if (parts.length >= 2) {
    // 有分隔符：只取 --- 之后的内容作为内部展示
    internalContent = parts.slice(1).join(" ").trim();
  } else {
    // 没有分隔符：全部作为内部内容
    internalContent = introMarkdown.trim();
  }

  if (internalContent) {
    introHtml = await marked.parse(internalContent);
    hasIntro = true;
  }
} catch (e) {
  // 没有前言文件是正常的，静默忽略
}

// 4. 读取后记
let outroHtml = "";
let hasOutro = false;
try {
  const outroPath = path.join(
    process.cwd(),
    "src/images",
    collection,
    "outro.md",
  );
  const outroMarkdown = await fs.readFile(outroPath, "utf-8");

  const parts = outroMarkdown.split(/^---$/m);

  let internalContent = "";
  if (parts.length >= 2) {
    internalContent = parts.slice(1).join(" ").trim();
  } else {
    internalContent = outroMarkdown.trim();
  }

  if (internalContent) {
    outroHtml = await marked.parse(internalContent);
    hasOutro = true;
  }
} catch (e) {
  // 没有后记文件是正常的，静默忽略
}

// 5. 处理图片 - 使用 Astro Assets 进行优化
const galleryItems = await Promise.all(
  images.map(
    async ({
      filePath,
      imgData,
    }: {
      filePath: string;
      imgData: AstroImage;
    }) => {
      const fileName = filePath.split("/").pop() || "无标题";

      // 使用 getImage 生成优化版本的 WebP
      let optimizedSrc = imgData.src;
      try {
        const optimized = await getImage({
          // @ts-expect-error - Astro's getImage accepts imported image modules
          src: imgData,
          width: 1600,
          format: "webp",
          quality: 85,
        });
        optimizedSrc = optimized.src;
      } catch (e) {
        // 如果优化失败，使用原始路径
        console.warn(`Failed to optimize image: ${fileName}`, e);
      }

      // 使用工具函数提取 EXIF 数据
      const meta = await extractImageMetadata(
        collection,
        fileName,
        optimizedSrc,
      );

      return meta;
    },
  ),
);

const hasImages = galleryItems.length > 0;
const initialItem = hasImages
  ? galleryItems[0]
  : {
      src: "",
      title: "暂无图片",
      year: "",
      location: "",
      specs: { camera: "", lens: "", aperture: "", shutter: "", iso: "" },
      desc: "",
    };

// 5. 精简客户端数据 - 只传输前端需要的字段
const clientSideData = toClientData(galleryItems);
---

<BaseLayout title={mainTitle} description={`${mainTitle} - ${subTitle}`}>
  <div class="w-full h-screen bg-white dark:bg-black text-black dark:text-white overflow-hidden relative font-mono">

    <!-- 简洁顶部栏 -->
    <header class="fixed top-0 left-0 w-full z-40 flex items-center justify-between px-4 py-3 border-b-2 border-black dark:border-white">
      <a href="/" class="text-sm uppercase tracking-widest hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black px-2 py-1">← 首页</a>
      <span class="text-sm uppercase tracking-widest">{mainTitle}</span>
      <div class="flex items-center gap-4">
        <!-- 模式切换按钮 -->
        <button id="mode-toggle" class="text-sm uppercase tracking-widest hover:underline cursor-pointer" role="button" tabindex="0" aria-label="切换视图模式">
          [ 详情模式 ]
        </button>
        <div class="w-16"></div>
      </div>
    </header>

    <main class="relative w-full h-full flex items-center justify-center pt-14 pb-16">
        {hasImages ? (
          <>
            <!-- 左导航 -->
            <button id="prev-btn" class="absolute left-0 top-14 bottom-16 w-20 z-30 flex items-center justify-center text-3xl font-bold cursor-pointer" aria-label="上一张">
              ‹
            </button>

            <!-- 简要模式 - 图片居中，底部显示信息 -->
            <div id="brief-mode" class="relative z-10 max-w-[90%] max-h-[75vh] flex flex-col items-center">
                <!-- 保护层 -->
                <div class="protection-overlay" aria-hidden="true"></div>
                <img id="main-image" alt={initialItem.title} src={initialItem.src} class="block w-auto h-auto max-h-[65vh] object-contain" loading="eager" />
                <span id="image-status" class="sr-only" aria-live="polite" aria-atomic="true"></span>

                <!-- 图片下方信息 -->
                <div class="w-full mt-4 flex items-baseline justify-between border-t-2 border-black dark:border-white pt-2">
                    <h1 id="image-title" class="text-lg font-bold">{initialItem.title}</h1>
                    <p id="image-meta" class="text-sm">{initialItem.year}</p>
                </div>
            </div>

            <!-- 详情模式 - 左侧图片 + 右侧信息 -->
            <div id="detail-mode" class="hidden relative z-10 w-[90%] h-[75vh] flex gap-8">
                <!-- 左侧图片区域 -->
                <div class="flex-1 flex items-center justify-center">
                    <img id="detail-image" alt={initialItem.title} src={initialItem.src} class="max-h-full max-w-full object-contain" loading="eager" />
                </div>
                <!-- 右侧信息面板 -->
                <div class="w-[350px] flex flex-col border-l-2 border-black dark:border-white pl-6">
                    <div class="flex-1 overflow-y-auto py-4">
                        <div class="space-y-4">
                            <!-- 标题区域 -->
                            <div class="border-b-2 border-black dark:border-white pb-3">
                                <p id="detail-year" class="text-xs uppercase tracking-widest mb-1">{initialItem.year}</p>
                                <p id="detail-location" class="text-xs uppercase tracking-widest mb-2 hidden">[ <span id="detail-location-text"></span> ]</p>
                                <h1 id="detail-title" class="text-xl font-bold uppercase wrap-break-words">{initialItem.title}</h1>
                            </div>

                            <!-- 描述 -->
                            <div class="border-b-2 border-black dark:border-white pb-3">
                                <p id="detail-desc" class="text-sm leading-relaxed">{initialItem.desc || '暂无描述'}</p>
                            </div>

                            <!-- Story 跳转按钮 -->
                            <div id="detail-story-container" class="hidden border-b-2 border-black dark:border-white pb-3">
                                <a id="detail-story-link" href="" class="inline-flex items-center gap-2 text-sm font-bold border-2 border-black dark:border-white px-4 py-2 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors">
                                    <span>📖</span>
                                    <span id="detail-story-text">阅读故事</span>
                                </a>
                            </div>

                            <!-- 技术参数 - 表格形式 -->
                            <div id="detail-specs-grid" class="grid grid-cols-2 gap-2 text-xs">
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">相机</span>
                                    <span id="detail-spec-camera" class="font-bold">--</span>
                                </div>
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">镜头</span>
                                    <span id="detail-spec-lens" class="font-bold">--</span>
                                </div>
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">光圈</span>
                                    <span id="detail-spec-aperture" class="font-bold">--</span>
                                </div>
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">快门</span>
                                    <span id="detail-spec-shutter" class="font-bold">--</span>
                                </div>
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">感光度</span>
                                    <span id="detail-spec-iso" class="font-bold">--</span>
                                </div>
                                <div class="border border-black dark:border-white p-2">
                                    <span class="block text-xs uppercase tracking-widest opacity-60">焦距</span>
                                    <span id="detail-spec-focal" class="font-bold">--</span>
                                </div>
                            </div>

                            <!-- 隐藏技术参数按钮（显示时） -->
                            <div id="specs-hide-btn" class="border-b-2 border-black dark:border-white pb-3 mt-3">
                                <button class="text-xs uppercase tracking-widest hover:underline cursor-pointer" role="button" tabindex="0" aria-label="隐藏技术参数">
                                    [ 隐藏参数 ]
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- 底部显示技术参数按钮（隐藏时）- 放在可滚动区域外，紧贴底部 -->
                    <div id="specs-show-btn" class="hidden border-t-2 border-black dark:border-white pt-3">
                        <button class="text-xs uppercase tracking-widest hover:underline cursor-pointer" role="button" tabindex="0" aria-label="显示技术参数">
                            [ 显示参数 ]
                        </button>
                    </div>
                </div>
            </div>

            <!-- 右导航 -->
            <button id="next-btn" class="absolute right-0 top-14 bottom-16 w-20 z-30 flex items-center justify-center text-3xl font-bold cursor-pointer" aria-label="下一张">
              ›
            </button>
          </>
        ) : (
          <div class="text-center p-10 border-2 border-black dark:border-white"><h2 class="text-xl">暂无图片</h2></div>
        )}
    </main>

    <!-- 数字索引进度条 -->
    {hasImages && (
      <footer class="fixed bottom-0 left-0 w-full z-40 flex items-center justify-center border-t-2 border-black dark:border-white bg-white dark:bg-black">
          <div class="flex items-center gap-4 py-3 px-4">
              <span id="current-index" class="text-2xl font-bold">01</span>
              <span class="text-xl">/</span>
              <span id="total-count" class="text-xl">{galleryItems.length.toString().padStart(2, '0')}</span>
          </div>
      </footer>
    )}

    {hasIntro && introHtml && (
      <div id="intro-cover" class="fixed inset-0 z-60 bg-white dark:bg-black overflow-y-auto">
          <div class="min-h-full flex items-center justify-center p-6 md:p-12">
              <div class="max-w-2xl w-full">

                  <div class="mb-8">
                      <h1 class="text-4xl md:text-6xl font-bold uppercase tracking-widest border-b-4 border-black dark:border-white pb-4">{mainTitle}</h1>
                      {subTitle && <p class="text-lg md:text-xl mt-4 uppercase tracking-widest">{subTitle}</p>}
                  </div>

                  <div class="text-lg md:text-xl leading-relaxed mb-12 whitespace-pre-wrap" set:html={introHtml}>
                  </div>

                  <button id="start-btn" class="text-xl font-bold uppercase tracking-widest border-2 border-black dark:border-white px-8 py-3 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black" aria-label="开始浏览">
                      开始 →
                  </button>
              </div>
          </div>
      </div>
    )}

    <!-- 后记覆盖层 -->
    {hasOutro && outroHtml && (
      <div id="outro-cover" class="fixed inset-0 z-60 bg-white dark:bg-black overflow-y-auto hidden">
          <div class="min-h-full flex items-center justify-center p-6 md:p-12">
              <div class="max-w-2xl w-full">

                  <div class="mb-8">
                      <h1 class="text-4xl md:text-6xl font-bold uppercase tracking-widest border-b-4 border-black dark:border-white pb-4">剧终</h1>
                  </div>

                  <div class="text-lg md:text-xl leading-relaxed mb-12 whitespace-pre-wrap" set:html={outroHtml}>
                  </div>

                  <div class="flex flex-col sm:flex-row gap-4">
                      <button id="restart-btn" class="text-xl font-bold uppercase tracking-widest border-2 border-black dark:border-white px-8 py-3 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black" aria-label="重新浏览">
                          ↺ 重新开始
                      </button>
                      <a href="/" class="text-xl font-bold uppercase tracking-widest border-2 border-black dark:border-white px-8 py-3 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black text-center" aria-label="返回首页">
                          ← 首页
                      </a>
                  </div>
              </div>
          </div>
      </div>
    )}

    <!-- 详情面板 - 粗野主义风格 -->
    <div id="details-overlay" class="fixed inset-0 z-100 bg-white dark:bg-black w-full h-full overflow-hidden opacity-0 pointer-events-none" role="dialog" aria-modal="true" aria-labelledby="overlay-title">
        <!-- 关闭按钮 -->
        <div class="absolute top-0 right-0 z-50 p-4">
            <button class="close-overlay-btn text-xl font-bold border-2 border-black dark:border-white px-3 py-1 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black" aria-label="关闭详情">
                × 关闭
            </button>
        </div>

        <!-- 桌面端布局 -->
        <div class="hidden md:flex w-full h-full">
            <!-- 左侧图片 -->
            <div class="w-2/3 h-full flex items-center justify-center p-8 border-r-2 border-black dark:border-white">
                <img id="overlay-img" alt="" class="max-h-[90vh] max-w-full object-contain" src="" />
            </div>
            <!-- 右侧信息 -->
            <div class="w-1/3 h-full overflow-y-auto p-6">
                <div class="space-y-6">
                    <!-- 标题 -->
                    <div class="border-b-2 border-black dark:border-white pb-4">
                        <p id="overlay-year" class="text-sm uppercase tracking-widest mb-1">{initialItem.year}</p>
                        <p id="overlay-location" class="text-xs uppercase tracking-widest mb-2 hidden">[ <span id="overlay-location-text"></span> ]</p>
                        <h1 id="overlay-title" class="text-2xl font-bold uppercase wrap-break-words">无标题</h1>
                    </div>

                    <!-- 描述 -->
                    <div class="border-b-2 border-black dark:border-white pb-4">
                        <p id="overlay-desc" class="text-sm leading-relaxed">暂无描述</p>
                    </div>

                    <!-- Story 跳转按钮 -->
                    <div id="story-link-container" class="hidden border-b-2 border-black dark:border-white pb-4">
                        <a id="story-link" href="" class="inline-flex items-center gap-2 text-sm font-bold border-2 border-black dark:border-white px-4 py-2 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors">
                            <span>📖</span>
                            <span id="story-link-text">阅读故事</span>
                        </a>
                    </div>

                    <!-- 技术参数 - 表格形式 -->
                    <div class="grid grid-cols-2 gap-2 text-sm">
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">相机</span>
                            <span id="spec-camera" class="font-bold">--</span>
                        </div>
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">镜头</span>
                            <span id="spec-lens" class="font-bold">--</span>
                        </div>
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">光圈</span>
                            <span id="spec-aperture" class="font-bold">--</span>
                        </div>
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">快门</span>
                            <span id="spec-shutter" class="font-bold">--</span>
                        </div>
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">感光度</span>
                            <span id="spec-iso" class="font-bold">--</span>
                        </div>
                        <div class="border border-black dark:border-white p-2">
                            <span class="block text-xs uppercase tracking-widest opacity-60">焦距</span>
                            <span id="spec-focal" class="font-bold">--</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 移动端布局 -->
        <div class="md:hidden flex flex-col h-full">
            <div class="flex-1 flex items-center justify-center p-4">
                <img id="overlay-img-mobile" alt="" class="max-h-[50vh] max-w-full object-contain" src="" />
            </div>
            <div class="border-t-2 border-black dark:border-white p-4 space-y-4">
                <div class="flex justify-between items-start">
                    <div>
                        <p id="overlay-year-mobile" class="text-xs uppercase tracking-widest">{initialItem.year}</p>
                        <p id="overlay-location-mobile" class="text-xs hidden">[<span id="overlay-location-text-mobile"></span>]</p>
                        <h1 id="overlay-title-mobile" class="text-lg font-bold uppercase">无标题</h1>
                    </div>
                    <button class="close-overlay-btn text-sm font-bold border border-black dark:border-white px-2 py-1">×</button>
                </div>
                <div class="text-xs grid grid-cols-4 gap-1">
                    <span id="spec-camera-mobile" class="truncate border border-black dark:border-white p-1">--</span>
                    <span id="spec-aperture-mobile" class="border border-black dark:border-white p-1">--</span>
                    <span id="spec-shutter-mobile" class="border border-black dark:border-white p-1">--</span>
                    <span id="spec-iso-mobile" class="border border-black dark:border-white p-1">--</span>
                </div>
                <p id="overlay-desc-mobile" class="text-xs">暂无描述</p>
                <!-- Story 跳转按钮 - 移动端 -->
                <a id="story-link-mobile" href="" class="hidden inline-flex items-center justify-center gap-2 text-sm font-bold border-2 border-black dark:border-white px-4 py-2 mt-2 hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors">
                    <span>📖</span>
                    <span id="story-link-text-mobile">阅读故事</span>
                </a>
            </div>
        </div>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ clientSideData }}>
  // 把逻辑封装到一个初始化函数中
  function initGallery() {
      const images = clientSideData;

      // 如果没有图片，直接返回
      if (!images || images.length === 0) return;

      const startBtn = document.getElementById('start-btn');
      const introCover = document.getElementById('intro-cover');
      const outroCover = document.getElementById('outro-cover');
      const restartBtn = document.getElementById('restart-btn');

      if (startBtn && introCover) {
          startBtn.addEventListener('click', () => {
              introCover.style.display = 'none';
          });
      }

      // 后记按钮事件
      if (restartBtn && outroCover) {
          restartBtn.addEventListener('click', () => {
              outroCover.classList.add('hidden');
              currentIndex = 0;
              updateView(currentIndex);
          });
      }

      let currentIndex = 0;
      let hasSeenOutro = false; // 追踪是否已经显示过后记
      let isDetailMode = false; // 当前视图模式：false = 简要模式，true = 详情模式

      // 批量获取 DOM 元素 - 减少重复查询
      const dom = {
          // 主视图
          mainImage: document.getElementById('main-image'),
          titleEl: document.getElementById('image-title'),
          metaEl: document.getElementById('image-meta'),
          currentIndexEl: document.getElementById('current-index'),
          // 模式切换
          modeToggle: document.getElementById('mode-toggle'),
          briefMode: document.getElementById('brief-mode'),
          detailMode: document.getElementById('detail-mode'),
          // 详情模式元素
          detailImage: document.getElementById('detail-image'),
          detailTitle: document.getElementById('detail-title'),
          detailYear: document.getElementById('detail-year'),
          detailLocation: document.getElementById('detail-location'),
          detailLocationText: document.getElementById('detail-location-text'),
          detailDesc: document.getElementById('detail-desc'),
          detailSpecCamera: document.getElementById('detail-spec-camera'),
          detailSpecLens: document.getElementById('detail-spec-lens'),
          detailSpecFocal: document.getElementById('detail-spec-focal'),
          detailSpecShutter: document.getElementById('detail-spec-shutter'),
          detailSpecIso: document.getElementById('detail-spec-iso'),
          detailSpecAperture: document.getElementById('detail-spec-aperture'),
          detailStoryContainer: document.getElementById('detail-story-container'),
          detailStoryLink: document.getElementById('detail-story-link'),
          detailStoryText: document.getElementById('detail-story-text'),
          // 技术参数显示/隐藏
          specsHideBtn: document.getElementById('specs-hide-btn'),
          specsShowBtn: document.getElementById('specs-show-btn'),
          detailSpecsGrid: document.getElementById('detail-specs-grid'),
          // 详情面板 - 桌面端（保留原有的详情面板功能）
          overlay: document.getElementById('details-overlay'),
          overlayImg: document.getElementById('overlay-img'),
          overlayTitle: document.getElementById('overlay-title'),
          overlayDesc: document.getElementById('overlay-desc'),
          overlayYear: document.getElementById('overlay-year'),
          overlayLocation: document.getElementById('overlay-location'),
          overlayLocationText: document.getElementById('overlay-location-text'),
          specCamera: document.getElementById('spec-camera'),
          specLens: document.getElementById('spec-lens'),
          specFocal: document.getElementById('spec-focal'),
          specShutter: document.getElementById('spec-shutter'),
          specIso: document.getElementById('spec-iso'),
          specAperture: document.getElementById('spec-aperture'),
          // 详情面板 - 移动端
          overlayImgMobile: document.getElementById('overlay-img-mobile'),
          overlayTitleMobile: document.getElementById('overlay-title-mobile'),
          overlayYearMobile: document.getElementById('overlay-year-mobile'),
          overlayLocationMobile: document.getElementById('overlay-location-mobile'),
          overlayLocationTextMobile: document.getElementById('overlay-location-text-mobile'),
          specCameraMobile: document.getElementById('spec-camera-mobile'),
          specApertureMobile: document.getElementById('spec-aperture-mobile'),
          specShutterMobile: document.getElementById('spec-shutter-mobile'),
          specIsoMobile: document.getElementById('spec-iso-mobile'),
          overlayDescMobile: document.getElementById('overlay-desc-mobile'),
          // Story 跳转按钮
          storyLinkContainer: document.getElementById('story-link-container'),
          storyLink: document.getElementById('story-link'),
          storyLinkText: document.getElementById('story-link-text'),
          storyLinkMobile: document.getElementById('story-link-mobile'),
          storyLinkTextMobile: document.getElementById('story-link-text-mobile'),
          // 按钮
          prevBtn: document.getElementById('prev-btn'),
          nextBtn: document.getElementById('next-btn'),
          infoTrigger: document.getElementById('info-trigger'),
          // 状态
          imageStatus: document.getElementById('image-status'),
      };

      const { mainImage, titleEl, metaEl, currentIndexEl, modeToggle, briefMode, detailMode, detailImage, detailTitle, detailYear, detailLocation, detailLocationText, detailDesc, detailSpecCamera, detailSpecLens, detailSpecFocal, detailSpecShutter, detailSpecIso, detailSpecAperture, detailStoryContainer, detailStoryLink, detailStoryText, specsHideBtn, specsShowBtn, detailSpecsGrid, overlay, overlayImg, overlayTitle, overlayDesc, overlayLocation, overlayLocationText, specCamera, specLens, specFocal, specShutter, specIso, specAperture, overlayImgMobile, overlayTitleMobile, overlayYearMobile, overlayLocationMobile, overlayLocationTextMobile, specCameraMobile, specApertureMobile, specShutterMobile, specIsoMobile, overlayDescMobile, storyLinkContainer, storyLink, storyLinkText, storyLinkMobile, storyLinkTextMobile, prevBtn, nextBtn, infoTrigger, imageStatus } = dom;

      const preloadImage = (src) => { const img = new Image(); img.src = src; };

      // ========== 增强预加载系统 ==========
      const PRELOAD_RANGE = 3; // 前后各预加载3张
      const preloadedUrls = new Set(); // 追踪已预加载的图片
      let preloadScheduled = false; // 避免重复调度

      // 智能预加载函数 - 使用 requestIdleCallback 不阻塞主线程
      function smartPreload(indices, priority = false) {
          const urlsToPreload = [];

          indices.forEach(idx => {
              const url = images[idx]?.src;
              if (url && !preloadedUrls.has(url)) {
                  preloadedUrls.add(url);
                  urlsToPreload.push(url);
              }
          });

          if (urlsToPreload.length === 0) return;

          if (priority) {
              // 高优先级：立即预加载（用户正在交互）
              urlsToPreload.forEach(url => preloadImage(url));
          } else {
              // 低优先级：使用 requestIdleCallback 在空闲时预加载
              if (!preloadScheduled) {
                  preloadScheduled = true;
                  if ('requestIdleCallback' in window) {
                      requestIdleCallback(() => {
                          urlsToPreload.forEach(url => preloadImage(url));
                          preloadScheduled = false;
                      }, { timeout: 2000 });
                  } else {
                      // 兼容不支持 requestIdleCallback 的浏览器
                      setTimeout(() => {
                          urlsToPreload.forEach(url => preloadImage(url));
                          preloadScheduled = false;
                      }, 100);
                  }
              }
          }
      }

      // 获取需要预加载的图片索引
      function getIndicesToPreload(currentIdx) {
          const indices = [];
          const len = images.length;

          // 前后各 PRELOAD_RANGE 张
          for (let i = 1; i <= PRELOAD_RANGE; i++) {
              indices.push((currentIdx + i) % len); // 下一张
              indices.push((currentIdx - i + len) % len); // 上一张
          }

          return indices;
      }

      // 初始预加载第一张周围的图片
      smartPreload(getIndicesToPreload(0), true);

      function updateView(index) {
        if (!images[index] || !mainImage) return;
        const item = images[index];

        setTimeout(() => {
            // 更新简要模式
            mainImage.src = item.src;
            if(titleEl) titleEl.textContent = item.title || '无标题';
            if(metaEl) metaEl.textContent = item.year || '--';

            // 更新详情模式
            if (detailImage) detailImage.src = item.src;
            if (detailTitle) detailTitle.textContent = item.title || '无标题';
            if (detailYear) detailYear.textContent = item.year || '--';
            if (detailDesc) detailDesc.innerHTML = item.desc || '暂无描述';

            // 位置信息
            const displayLocation = item.location?.trim() || '';
            if (detailLocation && displayLocation) {
                detailLocationText.textContent = displayLocation;
                detailLocation.classList.remove('hidden');
            } else if (detailLocation) {
                detailLocation.classList.add('hidden');
            }

            // 详情模式技术参数
            if (detailSpecCamera) detailSpecCamera.textContent = item.specs.camera || '--';
            if (detailSpecLens) detailSpecLens.textContent = item.specs.lens || '--';
            if (detailSpecAperture) detailSpecAperture.textContent = item.specs.aperture || '--';
            if (detailSpecShutter) detailSpecShutter.textContent = item.specs.shutter || '--';
            if (detailSpecIso) detailSpecIso.textContent = item.specs.iso || '--';
            if (detailSpecFocal) {
                const focalMatch = item.specs.lens?.match(/(\d+(?:\.\d+)?)\s*mm/i);
                detailSpecFocal.textContent = focalMatch ? focalMatch[1] + 'mm' : '--';
            }

            // 详情模式 Story 跳转按钮
            if (detailStoryContainer && detailStoryLink && detailStoryText) {
                if (item.story) {
                    detailStoryLink.href = `/stories/${item.story.slug}`;
                    detailStoryText.textContent = `阅读「${item.story.title}」`;
                    detailStoryContainer.classList.remove('hidden');
                } else {
                    detailStoryContainer.classList.add('hidden');
                }
            }

            // 更新数字索引
            if(currentIndexEl) {
                currentIndexEl.textContent = (index + 1).toString().padStart(2, '0');
            }

            // 更新屏幕阅读器状态
            if (imageStatus) imageStatus.textContent = `Image ${index + 1} of ${images.length}: ${item.title || 'untitled'}`;

            // 预加载
            smartPreload(getIndicesToPreload(index));
        }, 50);
      }

      function openOverlay() {
          const item = images[currentIndex];
          // 桌面端
          if(overlayImg) overlayImg.src = item.src;
          if(overlayTitle) overlayTitle.textContent = item.title;
          if(overlayDesc) overlayDesc.innerHTML = item.desc || '暂无描述';

          // 位置
          const displayLocation = item.location?.trim() || '';
          if (overlayLocation && displayLocation) {
              overlayLocationText.textContent = displayLocation;
              overlayLocation.classList.remove('hidden');
          } else if (overlayLocation) {
              overlayLocation.classList.add('hidden');
          }

          // 桌面端技术参数
          if(specCamera) specCamera.textContent = item.specs.camera || '--';
          if(specLens) specLens.textContent = item.specs.lens || '--';
          if(specAperture) specAperture.textContent = item.specs.aperture || '--';
          if(specShutter) specShutter.textContent = item.specs.shutter || '--';
          if(specIso) specIso.textContent = item.specs.iso || '--';
          if(specFocal) {
              const focalMatch = item.specs.lens?.match(/(\d+(?:\.\d+)?)\s*mm/i);
              specFocal.textContent = focalMatch ? focalMatch[1] + 'mm' : '--';
          }

          // 移动端
          if(overlayImgMobile) overlayImgMobile.src = item.src;
          if(overlayTitleMobile) overlayTitleMobile.textContent = item.title;
          if(overlayYearMobile) overlayYearMobile.textContent = item.year || '--';
          if(specCameraMobile) {
              const cameraParts = (item.specs.camera || '').split(' ');
              specCameraMobile.textContent = cameraParts.length > 1 ? cameraParts.slice(1).join(' ') : (item.specs.camera || '--');
          }
          if(specApertureMobile) specApertureMobile.textContent = item.specs.aperture || '--';
          if(specShutterMobile) specShutterMobile.textContent = item.specs.shutter || '--';
          if(specIsoMobile) specIsoMobile.textContent = item.specs.iso || '--';
          if(overlayDescMobile) overlayDescMobile.innerHTML = item.desc || '暂无描述';

          // 位置显示
          if (overlayLocationMobile && overlayLocationTextMobile) {
              if (displayLocation) {
                  overlayLocationTextMobile.textContent = displayLocation;
                  overlayLocationMobile.classList.remove('hidden');
              } else {
                  overlayLocationMobile.classList.add('hidden');
              }
          }

          // Story 跳转按钮 - 桌面端
          if (storyLinkContainer && storyLink && storyLinkText) {
              if (item.story) {
                  storyLink.href = `/stories/${item.story.slug}`;
                  storyLinkText.textContent = `阅读「${item.story.title}」`;
                  storyLinkContainer.classList.remove('hidden');
              } else {
                  storyLinkContainer.classList.add('hidden');
              }
          }

          // Story 跳转按钮 - 移动端
          if (storyLinkMobile && storyLinkTextMobile) {
              if (item.story) {
                  storyLinkMobile.href = `/stories/${item.story.slug}`;
                  storyLinkTextMobile.textContent = `阅读「${item.story.title}」`;
                  storyLinkMobile.classList.remove('hidden');
              } else {
                  storyLinkMobile.classList.add('hidden');
              }
          }

          // 禁用背景滚动
          document.body.style.overflow = 'hidden';

          if(overlay) {
              overlay.classList.remove('opacity-0', 'pointer-events-none');
              overlay.classList.add('opacity-100', 'pointer-events-auto');
          }
      }

      function closeOverlay() {
          if (!overlay) return;
          overlay.classList.remove('opacity-100', 'pointer-events-auto');
          overlay.classList.add('opacity-0', 'pointer-events-none');
          // 恢复背景滚动
          document.body.style.overflow = '';
      }

      // 绑定点击事件
      // infoTrigger?.addEventListener('click', openOverlay); // 移除了原来的详情按钮，现在使用顶部模式切换

      // info-trigger 是 div，需要添加键盘支持
      // infoTrigger?.addEventListener('keydown', (e) => {
      //     if (e.key === 'Enter' || e.key === ' ') {
      //         e.preventDefault();
      //         openOverlay();
      //     }
      // });

      // 模式切换功能
      let showSpecs = true; // 是否显示技术参数

      function toggleMode() {
          isDetailMode = !isDetailMode;
          if (isDetailMode) {
              // 切换到详情模式
              if (modeToggle) modeToggle.textContent = '[ 概览模式 ]';
              if (briefMode) briefMode.classList.add('hidden');
              if (detailMode) detailMode.classList.remove('hidden');
          } else {
              // 切换到简要模式
              if (modeToggle) modeToggle.textContent = '[ 详情模式 ]';
              if (briefMode) briefMode.classList.remove('hidden');
              if (detailMode) detailMode.classList.add('hidden');
          }
      }

      // 技术参数显示/隐藏功能
      function toggleSpecs() {
          showSpecs = !showSpecs;
          if (showSpecs) {
              // 显示技术参数
              if (specsHideBtn) specsHideBtn.classList.remove('hidden');
              if (specsShowBtn) specsShowBtn.classList.add('hidden');
              if (detailSpecsGrid) detailSpecsGrid.classList.remove('hidden');
          } else {
              // 隐藏技术参数
              if (specsHideBtn) specsHideBtn.classList.add('hidden');
              if (specsShowBtn) specsShowBtn.classList.remove('hidden');
              if (detailSpecsGrid) detailSpecsGrid.classList.add('hidden');
          }
      }

      // 绑定技术参数切换按钮事件
      specsHideBtn?.addEventListener('click', toggleSpecs);
      specsHideBtn?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              toggleSpecs();
          }
      });

      specsShowBtn?.addEventListener('click', toggleSpecs);
      specsShowBtn?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              toggleSpecs();
          }
      });

      // 绑定模式切换按钮事件
      modeToggle?.addEventListener('click', toggleMode);
      modeToggle?.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              toggleMode();
          }
      });

      document.querySelectorAll('.close-overlay-btn').forEach(btn => btn.addEventListener('click', closeOverlay));

      const goNext = () => {
          currentIndex = (currentIndex + 1) % images.length;
          updateView(currentIndex);
          // 高优先级预加载用户即将看到的下一张
          smartPreload([(currentIndex + 1) % images.length], true);

          // 检测是否到了最后一张图片，如果是则显示后记
          if (!hasSeenOutro && outroCover && currentIndex === images.length - 1) {
              hasSeenOutro = true;
              // 延迟显示，让用户看到最后一张图片
              setTimeout(() => {
                  outroCover.classList.remove('hidden');
              }, 500);
          }
      };
      const goPrev = () => {
          currentIndex = (currentIndex - 1 + images.length) % images.length;
          updateView(currentIndex);
          // 高优先级预加载用户即将看到的上一张
          smartPreload([(currentIndex - 1 + images.length) % images.length], true);

          // 如果用户往回浏览到第一张，重置后记标志
          if (currentIndex === 0) {
              hasSeenOutro = false;
          }
      };

      nextBtn?.addEventListener('click', goNext);
      prevBtn?.addEventListener('click', goPrev);

      // 处理键盘事件（这是绑定在 document 上的，离开页面时必须移除！）
      const handleKeydown = (e) => {
         // 退出键 - 关闭详情面板（Overlay）
         if (e.key === 'Escape') {
             closeOverlay();
         }
         // 空格键 - 切换详情面板（仅在简要模式下有效）
         else if (e.key === ' ') {
             // 只有在简要模式且没有打开 Overlay 时才响应
             if (!isDetailMode && overlay?.classList.contains('opacity-0')) {
                 e.preventDefault();
                 openOverlay();
             } else if (!isDetailMode && overlay?.classList.contains('opacity-100')) {
                 e.preventDefault();
                 closeOverlay();
             }
         }
         // M 键 - 切换视图模式（简要模式 / 详情模式）
         else if (e.key === 'm' || e.key === 'M') {
             e.preventDefault();
             toggleMode();
         }
         // 左右键 - 翻页（两种视图模式下都支持，Overlay 打开时不支持）
         else if (e.key === 'ArrowRight') {
             // 只有在非 Overlay 状态下才翻页
             if (overlay?.classList.contains('opacity-0')) {
                 e.preventDefault();
                 goNext();
                 smartPreload([(currentIndex + 1) % images.length], true);
             }
         }
         else if (e.key === 'ArrowLeft') {
             // 只有在非 Overlay 状态下才翻页
             if (overlay?.classList.contains('opacity-0')) {
                 e.preventDefault();
                 goPrev();
                 smartPreload([(currentIndex - 1 + images.length) % images.length], true);
             }
         }
      };
      document.addEventListener('keydown', handleKeydown);

      // 改进清理函数 - 使用标志位防止重复清理
      let cleanupRan = false;
      const cleanup = () => {
          if (cleanupRan) return;
          cleanupRan = true;
          document.removeEventListener('keydown', handleKeydown);
          // 确保恢复 body 滚动状态
          document.body.style.overflow = '';
      };

      // 监听页面切换
      document.addEventListener('astro:before-swap', cleanup, { once: true });
      // 备用：页面卸载时也清理
      window.addEventListener('unload', cleanup, { once: true });
  }

  // 核心修复：监听 astro:page-load 事件
  // 无论是首次加载，还是从其他页面"返回"回来，这个事件都会触发
  document.addEventListener('astro:page-load', initGallery);
</script>

