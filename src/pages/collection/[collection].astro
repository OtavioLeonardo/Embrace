    transform: translateY(20px);
    opacity: 0;
    animation-delay: 0.1s;
}

@keyframes slideUp {
    to {
        transform: translateY(0);
        opacity: 1;
    }
}

/* 主图片切换过渡 */
#main-image {
    transition: opacity 0.2s ease-in-out;
}

/* 进度条按钮过渡 */
.dot-btn {
    transition: all 0.2s ease;
}

/* 信息触发器悬停效果 */
#info-trigger {
